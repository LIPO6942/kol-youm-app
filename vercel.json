{
    "crons": [
        {
            "path": "/api/send-weekly-notification",
            "schedule": "0 20 * * 0"
        },
        {
            "path": "/api/send-habit-notification?type=morning",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/send-habit-notification?type=evening",
            "schedule": "0 18 * * *"
        },
        {
            "path": "/api/send-monthly-wrapup-notification",
            "schedule": "0 10 1 * *"
        }
    ]
}